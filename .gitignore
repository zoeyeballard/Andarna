# Python / venv
.venv/
.venv-openvla/
__pycache__/
*.pyc

# Generated CR-stripped run scripts
scripts/.*_run.sh

# Large training/eval artifacts (checkpoints are ~200MB each)
outputs/train/
outputs/eval/
outputs/smoke/
outputs/*.log
outputs/*.txt

# Keep small summary artifacts that ARE committed (see below):
!outputs/results/

# HF / torch caches (these live in ~/.cache anyway, but just in case)
*.safetensors
wandb/

# .env files
.env

# prompts
Claude.md

# --- Project 2: openvla-robustness ---
# Raw per-trial logs and rollout videos are large/regenerable — commit only the
# aggregated summaries (summary.json / *.csv) and the figures.
openvla-robustness/results/**/trials.jsonl
# rollout videos: engine names them <run>_t<task>_e<ep>_<ok|fail>.mp4, so ignore the
# whole videos/ dir (and any stray mp4) rather than a rollout_* prefix that never matches.
openvla-robustness/results/**/videos/
openvla-robustness/results/**/*.mp4
openvla-robustness/**/*.npy
# HF model cache / checkpoints if they ever land in-tree
openvla-robustness/**/checkpoints/
openvla-robustness/**/*.bin
adapter_tmp/
# Local copy of the colab session log can get large
openvla-robustness/session_log.ipynb