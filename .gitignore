# Python / venv
.venv/
__pycache__/
*.pyc

# Generated CR-stripped run scripts
scripts/.*_run.sh

# Large training/eval artifacts (checkpoints are ~200MB each)
outputs/train/
outputs/eval/
outputs/smoke/
outputs/*.log
outputs/*.txt

# Keep small summary artifacts that ARE committed (see below):
!outputs/results/

# HF / torch caches (these live in ~/.cache anyway, but just in case)
*.safetensors
wandb/

# Secrets and prompt files (never commit)
.env
Claude.md
Project3.md

# Generated / large artifacts (spec boilerplate)
.ipynb_checkpoints/
runs/
*.pt
*.bin
adapter_tmp/
node_modules/

# --- Project 3: robotics-test-infra ---
# Local run outputs (videos, raw results JSON) are regenerable — commit only the
# small summaries under artifacts/summaries/ and the committed baseline.
robotics-test-infra/artifacts/*
!robotics-test-infra/artifacts/.gitignore
!robotics-test-infra/artifacts/summaries/
robotics-test-infra/**/__pycache__/
robotics-test-infra/.pytest_cache/
robotics-test-infra/.mypy_cache/
robotics-test-infra/.ruff_cache/
robotics-test-infra/**/*.mp4
# results JSON the evaluator writes locally; baselines/ is committed, results/ is not
robotics-test-infra/results/
